{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repave.dev/schemas/blueprint.schema.json",
  "title": "Repave Blueprint",
  "description": "Declares a versioned golden path: inputs, standard reference, template, gates, and output contract.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "repave.dev/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Blueprint"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["standard", "inputs", "template", "gates", "output"],
      "additionalProperties": false,
      "properties": {
        "standard": {
          "type": "object",
          "required": ["source", "version"],
          "additionalProperties": false,
          "properties": {
            "source": {
              "type": "string",
              "description": "Path or URI to the authoritative standards source."
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            }
          }
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/inputField"
          }
        },
        "template": {
          "type": "object",
          "required": ["engine", "path"],
          "additionalProperties": false,
          "properties": {
            "engine": {
              "type": "string",
              "enum": ["copier"]
            },
            "path": {
              "type": "string"
            }
          }
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "terraform-fmt",
              "terraform-validate",
              "terraform-test",
              "tflint",
              "checkov",
              "secrets",
              "docs-drift"
            ]
          }
        },
        "artifactType": {
          "type": "string",
          "enum": ["terraform-module", "ansible-role"],
          "default": "terraform-module",
          "description": "Generated artifact type; drives gate artifact hygiene paths."
        },
        "checkov": {
          "type": "object",
          "required": ["policies_source"],
          "additionalProperties": false,
          "properties": {
            "policies_source": {
              "type": "string",
              "description": "Repo-relative path to the Checkov custom policy pack copied into generated modules."
            },
            "policy_version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$",
              "description": "Semantic version of the policy pack encoded by this blueprint."
            }
          }
        },
        "gate_config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checkov": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "external_checks_dir": {
                  "type": "string",
                  "description": "Path relative to the generated module root for copied custom policies."
                },
                "config_file": {
                  "type": "string",
                  "description": "Checkov config file relative to the generated module root."
                },
                "skip_checks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Built-in or custom Checkov check IDs to skip."
                },
                "soft_fail": {
                  "type": "boolean",
                  "description": "Return exit code 0 when checks fail (report only)."
                }
              }
            },
            "tflint": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "config_file": {
                  "type": "string",
                  "description": "TFLint config file relative to the generated module root."
                }
              }
            },
            "terraform-validate": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "var_files": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Optional var files reserved for future validate/plan integration."
                }
              }
            },
            "terraform-test": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "test_directory": {
                  "type": "string",
                  "description": "Directory containing .tftest.hcl files relative to module root."
                }
              }
            }
          }
        },
        "output": {
          "type": "object",
          "required": ["type", "repository"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["pull_request", "directory"]
            },
            "repository": {
              "type": "object",
              "required": ["name_template"],
              "additionalProperties": false,
              "properties": {
                "name_template": {
                  "type": "string",
                  "description": "GitHub repository name template. Supports {module_name} and blueprint input placeholders such as {cloud_provider}."
                },
                "title_template": {
                  "type": "string",
                  "description": "Publish title template. Placeholders must match blueprint input names."
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "inputField": {
      "type": "object",
      "required": ["name", "type", "required"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "integer"]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "default": {},
        "enum": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
