---
galaxy_info:
  role_name: {{ role_name }}
  namespace: {{ namespace }}
  author: platform-engineering
  description: {{ description }}
  license: Apache-2.0
  min_ansible_version: "{{ min_ansible_version }}"
  platforms:
{%- for entry in target_platforms.split(',') %}
{%- set trimmed = entry.strip() %}
{%- if trimmed %}
{%- set parts = trimmed.split(':', 1) %}
    - name: {{ parts[0].strip() }}
      versions:
        - "{{ parts[1].strip() if parts|length > 1 else 'all' }}"
{%- endif %}
{%- endfor %}

dependencies: []
