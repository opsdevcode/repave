variable "module_name" {
  type        = string
  description = "Name of this module instance."
  default     = "{{ module_name }}"
}

variable "cloud_provider" {
  type        = string
  description = "Cloud provider this module targets."
  default     = "{{ cloud_provider }}"
}

variable "provider_services" {
  type        = list(string)
  description = "Provider services in scope for this module."
  default     = [{% for svc in provider_services.split(',') %}"{{ svc.strip() }}"{% if not loop.last %}, {% endif %}{% endfor %}]
}

variable "provider_service_scope" {
  type        = string
  description = "JSON map of resource capabilities selected for each provider service."
  default     = {{ provider_service_scope | tojson }}
}

variable "environment" {
  type        = string
  description = "Deployment environment (for example dev, stage, prod)."
  default     = "dev"
}

variable "tags" {
  type        = map(string)
  description = "Resource tags applied by the module."
  default     = {}
}
