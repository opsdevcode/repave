# {{ cloud_provider | upper }} {{ service }} — {{ resource }}
# Replace this scaffold with {{ cloud_provider }}_{{ service }}_{{ resource }}.
resource "null_resource" "{{ file_stem }}" {
  triggers = {
    service        = "{{ service }}"
    resource       = "{{ resource }}"
    cloud_provider = local.cloud_provider
    module_name    = var.module_name
    environment    = var.environment
    tags           = jsonencode(var.tags)
  }
}
